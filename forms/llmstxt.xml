<?xml version="1.0" encoding="UTF-8"?>
<form>
	<fields name="params">
		<fieldset name="llmstxt_general" label="PLG_TASK_LLMSTXT_FIELDSET_GENERAL_LABEL">

			<field
				name="base_url"
				type="url"
				label="PLG_TASK_LLMSTXT_BASE_URL_LABEL"
				description="PLG_TASK_LLMSTXT_BASE_URL_DESC"
				filter="url"
				hint="https://www.example.com"
			/>

			<field
				name="output_file"
				type="text"
				label="PLG_TASK_LLMSTXT_OUTPUT_FILE_LABEL"
				description="PLG_TASK_LLMSTXT_OUTPUT_FILE_DESC"
				default="llms.txt"
				filter="cmd"
			/>

			<field
				name="remove_language_code"
				type="radio"
				layout="joomla.form.field.radio.switcher"
				label="PLG_TASK_LLMSTXT_REMOVE_LANGUAGE_CODE_LABEL"
				description="PLG_TASK_LLMSTXT_REMOVE_LANGUAGE_CODE_DESC"
				default="0"
			>
				<option value="0">JNO</option>
				<option value="1">JYES</option>
			</field>

			<field
				name="site_title"
				type="text"
				label="PLG_TASK_LLMSTXT_SITE_TITLE_LABEL"
				description="PLG_TASK_LLMSTXT_SITE_TITLE_DESC"
				maxlength="255"
			/>

			<field
				name="summary"
				type="textarea"
				label="PLG_TASK_LLMSTXT_SUMMARY_LABEL"
				description="PLG_TASK_LLMSTXT_SUMMARY_DESC"
				rows="3"
				filter="string"
			/>

			<field
				name="intro"
				type="textarea"
				label="PLG_TASK_LLMSTXT_INTRO_LABEL"
				description="PLG_TASK_LLMSTXT_INTRO_DESC"
				rows="4"
				filter="string"
			/>

			<field
				name="sections"
				type="subform"
				label="PLG_TASK_LLMSTXT_SECTIONS_LABEL"
				description="PLG_TASK_LLMSTXT_SECTIONS_DESC"
				multiple="true"
				layout="joomla.form.field.subform.repeatable"
				icon="list"
			>
				<form>
					<field
						name="heading"
						type="text"
						label="PLG_TASK_LLMSTXT_SECTION_HEADING_LABEL"
						filter="string"
					/>

					<field
						name="source"
						type="list"
						label="PLG_TASK_LLMSTXT_SECTION_SOURCE_LABEL"
						default="menu"
					>
						<option value="menu">PLG_TASK_LLMSTXT_SECTION_SOURCE_MENU</option>
						<option value="category">PLG_TASK_LLMSTXT_SECTION_SOURCE_CATEGORY</option>
						<option value="articles">PLG_TASK_LLMSTXT_SECTION_SOURCE_ARTICLES</option>
					</field>

					<field
						name="menutype"
						type="menutype"
						addfieldprefix="Joomill\Plugin\Task\Llmstxt\Field"
						label="PLG_TASK_LLMSTXT_SECTION_MENUTYPE_LABEL"
						showon="source:menu"
					/>

					<field
						name="menu_include"
						type="menuitems"
						addfieldprefix="Joomill\Plugin\Task\Llmstxt\Field"
						multiple="true"
						label="PLG_TASK_LLMSTXT_SECTION_MENU_INCLUDE_LABEL"
						description="PLG_TASK_LLMSTXT_SECTION_MENU_INCLUDE_DESC"
						showon="source:menu"
					/>

					<field
						name="menu_exclude"
						type="menuitems"
						addfieldprefix="Joomill\Plugin\Task\Llmstxt\Field"
						multiple="true"
						label="PLG_TASK_LLMSTXT_SECTION_MENU_EXCLUDE_LABEL"
						description="PLG_TASK_LLMSTXT_SECTION_MENU_EXCLUDE_DESC"
						showon="source:menu"
					/>

					<field
						name="include_submenu"
						type="radio"
						layout="joomla.form.field.radio.switcher"
						label="PLG_TASK_LLMSTXT_SECTION_INCLUDE_SUBMENU_LABEL"
						description="PLG_TASK_LLMSTXT_SECTION_INCLUDE_SUBMENU_DESC"
						default="1"
						showon="source:menu"
					>
						<option value="0">JNO</option>
						<option value="1">JYES</option>
					</field>

					<field
						name="categories"
						type="category"
						extension="com_content"
						multiple="true"
						layout="joomla.form.field.list-fancy-select"
						label="PLG_TASK_LLMSTXT_SECTION_CATEGORIES_LABEL"
						showon="source:category"
					/>

					<field
						name="include_subcategories"
						type="radio"
						layout="joomla.form.field.radio.switcher"
						label="PLG_TASK_LLMSTXT_SECTION_INCLUDE_SUBCATEGORIES_LABEL"
						description="PLG_TASK_LLMSTXT_SECTION_INCLUDE_SUBCATEGORIES_DESC"
						default="0"
						showon="source:category"
					>
						<option value="0">JNO</option>
						<option value="1">JYES</option>
					</field>

					<field
						name="article_include"
						type="sql"
						multiple="true"
						query="SELECT id AS value, title AS text FROM #__content WHERE state = 1 ORDER BY title ASC"
						key_field="value"
						value_field="text"
						layout="joomla.form.field.list-fancy-select"
						label="PLG_TASK_LLMSTXT_SECTION_ARTICLE_INCLUDE_LABEL"
						description="PLG_TASK_LLMSTXT_SECTION_ARTICLE_INCLUDE_DESC"
						showon="source:category,articles"
					/>

					<field
						name="article_exclude"
						type="sql"
						multiple="true"
						query="SELECT id AS value, title AS text FROM #__content WHERE state = 1 ORDER BY title ASC"
						key_field="value"
						value_field="text"
						layout="joomla.form.field.list-fancy-select"
						label="PLG_TASK_LLMSTXT_SECTION_ARTICLE_EXCLUDE_LABEL"
						description="PLG_TASK_LLMSTXT_SECTION_ARTICLE_EXCLUDE_DESC"
						showon="source:category,articles"
					/>

					<field
						name="language"
						type="contentlanguage"
						label="PLG_TASK_LLMSTXT_SECTION_LANGUAGE_LABEL"
						description="PLG_TASK_LLMSTXT_SECTION_LANGUAGE_DESC"
						default=""
					>
						<option value="">PLG_TASK_LLMSTXT_SECTION_LANGUAGE_ALL</option>
					</field>

					<field
						name="description_source"
						type="list"
						label="PLG_TASK_LLMSTXT_SECTION_DESCSRC_LABEL"
						default="auto"
					>
						<option value="auto">PLG_TASK_LLMSTXT_SECTION_DESCSRC_AUTO</option>
						<option value="metadesc">PLG_TASK_LLMSTXT_SECTION_DESCSRC_METADESC</option>
						<option value="introtext">PLG_TASK_LLMSTXT_SECTION_DESCSRC_INTROTEXT</option>
						<option value="none">PLG_TASK_LLMSTXT_SECTION_DESCSRC_NONE</option>
					</field>

					<field
						name="limit"
						type="number"
						label="PLG_TASK_LLMSTXT_SECTION_LIMIT_LABEL"
						default="50"
						min="0"
						step="1"
					/>

					<field
						name="max_age"
						type="number"
						label="PLG_TASK_LLMSTXT_SECTION_MAX_AGE_LABEL"
						description="PLG_TASK_LLMSTXT_SECTION_MAX_AGE_DESC"
						default="0"
						min="0"
						step="1"
						showon="source:category,articles"
					/>

					<field
						name="ordering"
						type="list"
						label="PLG_TASK_LLMSTXT_SECTION_ORDERING_LABEL"
						default="created_desc"
						showon="source:category,articles"
					>
						<option value="created_desc">PLG_TASK_LLMSTXT_SECTION_ORDERING_CREATED_DESC</option>
						<option value="ordering_asc">PLG_TASK_LLMSTXT_SECTION_ORDERING_ORDERING_ASC</option>
						<option value="title_asc">PLG_TASK_LLMSTXT_SECTION_ORDERING_TITLE_ASC</option>
					</field>
				</form>
			</field>

			<!-- Cross-sell: Joomill Markdown plugin -->
			<field
				name="markdownpromo"
				type="note"
				description="PLG_TASK_LLMSTXT_MARKDOWNPROMO_DESC"
			/>

		</fieldset>
	</fields>
</form>
